# Copy this to .env and fill in your values
# .env is gitignored — never commit it

# GovTribe MCP Bearer token (auto-extracted from Claude Code config)
GOVTRIBE_BEARER_TOKEN=eyJ...

# Discord webhook URL
# Create one: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# How often the scanner loops (only used with --loop flag)
SCAN_INTERVAL_HOURS=24
ANTHROPIC_API_KEY=sk-ant-...
